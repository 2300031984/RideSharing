# Backend environment variables for local development / deployment
# Copy this file to ".env" and fill in your secrets (do NOT commit .env).

# Server
PORT=8081

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ridesharing_db

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=replace_with_a_strong_secret

# Stripe (optional)
STRIPE_API_SECRET_KEY=sk_test_replace_with_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Zipkin / Tracing (optional)
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# CORS (use the deployed frontend URL in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
